programa {
  funcao inicio() {
    escreva("Hunter 350\n")
    inteiro consm = 15 + 21
   inteiro vel
   vel = 120
   escreva("velocidade maxima: " + vel)
    vel = 181
   escreva("\nPeso maximo: " + vel+"kg\n")
   vel = 13
   escreva("capacidade do tanque: " + vel + "Lts\n")
   vel = 15 ^ 17
   escreva("consumo medio: " + vel + "~" + consm + "km/L\n")
  }
}
