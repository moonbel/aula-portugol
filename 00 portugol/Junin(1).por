programa {
  funcao inicio() {
    real analiseDenins = 500.00
    real clientePorhora = 350.00
    real horas 


escreva("Quantidade estimada de horas: ")
leia(horas)

real totalDehoras = (clientePorhora * horas) 

escreva("o total cobrado: R$" + totalDehoras)
real totallucro = totalDehoras - analiseDenins

escreva("\nQuanto o junin deve cobrar do seu cliente: R$" + totallucro)



     
     









}



}