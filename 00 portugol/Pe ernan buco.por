programa {
  funcao inicio() {
   real custosMensais = 500
   real doasoesDiarias = 25
   real totalDefalta
real totalDefalta = custosMensais - doasoesDiarias
   escreva("total da mensalidade R4: " + custosMensais)
   escreva("\nDoações diárias R$: " + doasoesDiarias)
   escreva("\nTotal de quanto falta para completar: " + totalDefalta)

   

 
 



   


 }

